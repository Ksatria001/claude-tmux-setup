#!/bin/zsh
# Status-line indicator for the claude tmux workspace.
# Reports whether pane 1.1 (claude) and pane 1.2 (live-view) and 1.3 (lint)
# have a foreground child process, using green/red dots.
#
# Usage: workspace-status [session-name]
#   - Called by tmux's status-right via `#(~/.local/bin/workspace-status #S)`
#     so each session reports its own panes.
#   - Defaults to "claude" if no argument is passed (back-compat for the
#     single-session legacy setup).

SESSION="${1:-claude}"

ok="#[fg=#9ece6a]●#[default]"
bad="#[fg=#f7768e]●#[default]"

check_pane() {
  local pid
  pid=$(tmux display-message -t "$SESSION:$1" -p '#{pane_pid}' 2>/dev/null)
  # macOS pgrep -P returns nothing without a pattern; use ps for portability
  if [[ -n "$pid" ]] && ps -A -o ppid= | grep -qE "^[[:space:]]*${pid}\$"; then
    print -n -- "$ok"
  else
    print -n -- "$bad"
  fi
}

printf '%s claude  %s live-view  %s lint' \
  "$(check_pane 1.1)" "$(check_pane 1.2)" "$(check_pane 1.3)"
